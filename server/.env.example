NODE_ENV=development
PORT=3000

# Local development DB (PostgreSQL)
# Example:
# DATABASE_URL_DEV=postgresql://postgres:password@127.0.0.1:5432/SIMAdb
DATABASE_URL_DEV=

# Local test DB (PostgreSQL)
# Example:
# DATABASE_URL_TEST=postgresql://postgres:password@127.0.0.1:5432/SIMAdb_test
DATABASE_URL_TEST=

# Production DB connection string (Neon/Render):
# Example format:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# JWT Configuration
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# Comma-separated frontend origins allowed to call this API
# Example:
# CORS_ORIGIN=https://your-vercel-app.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Default password for new Dosen created via Excel upload
DEFAULT_PASSWORD_DOSEN=12345678
